<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!--
        Include the main app preferences but exclude the per-number debounce keys
        (last_text_XXXXX) because they contain callers' phone numbers (PII) and
        there is no user consent for those to leave the device via cloud backup.
    -->
    <include domain="sharedpref" path="app_preferences.preferences_pb" />
    <include domain="sharedpref" path="call_history.preferences_pb" />
    <exclude domain="sharedpref" path="." />
</full-backup-content>
